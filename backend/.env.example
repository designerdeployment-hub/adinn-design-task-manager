# Local development
NODE_ENV=development
PORT=5001
FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET=change_this_to_a_long_random_secret_before_deploy
JWT_EXPIRES_IN=7d
TRUST_PROXY=false
MAX_FILE_SIZE_MB=50
MAX_FILES_PER_REQUEST=20

# Storage driver
# Use file for local/offline testing.
# Use supabase for Render Free / production persistence.
DATA_DRIVER=file
DATA_FILE=./data/db.json
UPLOAD_DIR=./uploads
BACKUP_DIR=./data/backups

# Supabase settings - required only when DATA_DRIVER=supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STATE_TABLE=app_state
SUPABASE_STATE_KEY=adinn-design-task-manager

# Permanent file/design storage
FILE_STORAGE_DRIVER=local
# For production use Supabase Storage:
# FILE_STORAGE_DRIVER=supabase
# SUPABASE_STORAGE_BUCKET=adinn-design-files
