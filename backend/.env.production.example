NODE_ENV=production
PORT=5001
FRONTEND_ORIGIN=https://your-vercel-frontend-url.vercel.app
JWT_SECRET=replace_with_output_from_node_src_scripts_generateSecret_js
JWT_EXPIRES_IN=7d
TRUST_PROXY=true
MAX_FILE_SIZE_MB=50
MAX_FILES_PER_REQUEST=20

# Supabase persistent database
DATA_DRIVER=supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_secret_or_service_role_key_keep_backend_only
SUPABASE_STATE_TABLE=app_state
SUPABASE_STATE_KEY=adinn-design-task-manager

# File uploads are still local on Render Free. Use Supabase Storage later for permanent uploaded files.
UPLOAD_DIR=./uploads
BACKUP_DIR=./data/backups

# Permanent file/design storage
FILE_STORAGE_DRIVER=local
# For production use Supabase Storage:
# FILE_STORAGE_DRIVER=supabase
# SUPABASE_STORAGE_BUCKET=adinn-design-files
